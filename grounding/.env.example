# You.com Search API (required)
YDC_API_KEY=your-ydc-api-key

# Verbose logging (0=off, 1=on). Shows full tool call details: query, params,
# search_uuid, interface, latency. Toggle at runtime or via --verbose flag.
GROUNDING_VERBOSE=0

# LLM Providers (set the ones you use)
ANTHROPIC_API_KEY=sk-ant-...       # Claude (claude-sonnet-4-6, claude-opus-4-6)
OPENAI_API_KEY=sk-...              # OpenAI (gpt-4.1, gpt-4.1-mini)
DASHSCOPE_API_KEY=sk-...           # Qwen via DashScope (qwen-plus-2025-09-11, qwen3-max)
HF_TOKEN=hf_...                    # Qwen via Hugging Face (Qwen/Qwen3-8B)
MOONSHOT_API_KEY=sk-...            # Kimi via Moonshot (kimi-k2.5)
TOGETHER_API_KEY=...               # Llama via Together AI (Llama-4-Maverick)

# Ollama needs no API key — just run: ollama pull llama4
